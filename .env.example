# Copy this file to .env and adapt values.

NOM_CONTENEUR=ostal-neige
MC_VERSION=1.21.11

PORT_SERVEUR=23600
RCON_PORT=21600
RCON_PASSWORD=CHANGE_ME
RCON_HOST=127.0.0.1

ATTACH_CONSOLE=yes
RESTART_POLICY=unless-stopped
STOP_TIMEOUT_SECONDS=30
CLEANUP_ON_LAUNCH=yes
AUTO_CREATE_LOG4J2=yes

RUN_AS_HOST_USER=yes
FIX_OWNERSHIP_ON_START=yes

USE_RESOURCE_LIMITS=yes
LIMIT_CPU=
LIMIT_MEMORY=36g

BIND_IP=

VOICECHAT_PORT=24753
DISCORDSRV_PORT=
BLUEMAP_PORT=24654
ADDITIONAL_PORTS_BOTH="7867 8192"
ADDITIONAL_PORTS_TCP=""
ADDITIONAL_PORTS_UDP=""

JAVA_OPTS=""

BACKUP_COMPRESSION_LEVEL=3
BACKUP_OUTPUT_DIR=backups
BACKUP_FILE_PREFIX=ostal-neige-backup
BACKUP_INCLUDE_PATHS="world world_nether world_the_end plugins config server.properties bukkit.yml commands.yml help.yml permissions.yml purpur.yml spigot.yml whitelist.json ops.json banned-ips.json banned-players.json wepif.yml"
BACKUP_EXCLUDE_PATTERNS="backups/* cache/* logs/* debug/* libraries/* versions/* *.tmp"

AUTO_TASKS_BACKUP_ENABLED=yes
AUTO_TASKS_BACKUP_HOUR=4
AUTO_TASKS_BACKUP_MINUTE=0

AUTO_TASKS_CLEANUP_ENABLED=yes
AUTO_TASKS_CLEANUP_HOUR=4
AUTO_TASKS_CLEANUP_MINUTE=20

AUTO_TASKS_RESTART_ENABLED=yes
AUTO_TASKS_RESTART_HOUR=4
AUTO_TASKS_RESTART_MINUTE=40

AUTO_TASKS_LOG_FILE=logs/fusada-auto-tasks.log